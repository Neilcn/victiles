{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  .collection-description-read-more {
    text-decoration: underline; 
    cursor: pointer;
    background: none;
    border: none;
    padding: 0;
    color: rgb(var(--color-link));
    font-family: inherit;
    font-size: inherit;
  }
{%- endstyle -%}

<div class="page-width section-{{ section.id }}-padding">
  {%- assign description = collection.description -%}
  {%- if description != blank -%}
    {%- assign plain_description = description | strip_html -%}
    {%- assign first_sentence = plain_description | split: '.' | first | append: '.' -%}
    
    <div class="collection-description rte">
      {%- if plain_description.size > first_sentence.size -%}
        <div id="ShortDesc-{{ section.id }}">
          <p>
            {{ first_sentence }}
            <button class="collection-description-read-more" onclick="document.getElementById('ShortDesc-{{ section.id }}').style.display='none';document.getElementById('FullDesc-{{ section.id }}').style.display='block';">Read More...</button>
          </p>
        </div>
        <div id="FullDesc-{{ section.id }}" style="display: none;">
          {{ description }}
        </div>
      {%- else -%}
        {{ description }}
      {%- endif -%}
    </div>
  {%- endif -%}
</div>

{% schema %}
{
  "name": "Collection Description",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Top",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 36
    }
  ],
  "presets": [
    {
      "name": "Collection Description"
    }
  ]
}
{% endschema %}
