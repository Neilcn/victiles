<script >
document.addEventListener('DOMContentLoaded', () => {
  const grid = document.getElementById('masonry-grid');
  const items = Array.from(grid.querySelectorAll('.masonry-item'));
  const clearBtn = document.getElementById('clear-filters');
  
  const activeFilters = {
    room: [],
    colour: [],
    style: []
  };

  function getUniqueValues(attributeName) {
    const values = new Set();
    items.forEach(item => {
      const rawVal = item.getAttribute(`data-${attributeName}`);
      if (rawVal) {
        // Split by comma and add each trimmed value
        rawVal.split(',').forEach(v => {
          const cleanV = v.trim();
          if(cleanV) values.add(cleanV);
        });
      }
    });
    return Array.from(values).sort();
  }

  function createButtons(groupName, values) {
    const container = document.querySelector(`#filter-group-${groupName} .filter-buttons`);
    if(!container) return;

    // Clear existing buttons to prevent duplicates if function runs multiple times
    container.innerHTML = '';

    values.forEach(val => {
      if(!val) return;
      
      const btn = document.createElement('button');
      btn.type = 'button';
      btn.className = 'filter-btn';
      btn.textContent = val;
      btn.dataset.value = val;
      btn.dataset.group = groupName;
      
      btn.addEventListener('click', (e) => {
        toggleFilter(groupName, val, e.target);
      });
      
      container.appendChild(btn);
    });
  }

  function toggleFilter(group, value, btnElement) {
    // Check if this value is currently selected
    const index = activeFilters[group].indexOf(value);

    if (index > -1) {
      // It is selected, remove it
      activeFilters[group].splice(index, 1);
      btnElement.classList.remove('active');
    } else {
      // It is not selected, add it
      activeFilters[group].push(value);
      btnElement.classList.add('active');
    }
    
    applyFilters();
  }

  function applyFilters() {
    // Check if we have any active filters at all
    const hasActiveFilters = Object.values(activeFilters).some(arr => arr.length > 0);
    
    items.forEach(item => {
      // Assume visible, then check against each group
      let isVisible = true;
      
      for (const [group, selectedValues] of Object.entries(activeFilters)) {
        if (selectedValues.length > 0) {
          // Get item's values for this group
          const rawItemValues = item.getAttribute(`data-${group}`);
          const itemValues = rawItemValues ? rawItemValues.split(',').map(s => s.trim()) : [];

          // Logic: Does the item have at least one of the selected values for this group? (OR logic within group)
          // If you wanted AND logic (item must have ALL selected values), we'd use .every
          const hasMatch = selectedValues.some(val => itemValues.includes(val));
          
          if (!hasMatch) {
            isVisible = false;
            break; // No need to check other groups if one block fails
          }
        }
      }
      
      if (isVisible) {
        item.classList.remove('hidden');
      } else {
        item.classList.add('hidden');
      }
    });

    if (hasActiveFilters) {
      if (clearBtn) clearBtn.classList.add('visible');
    } else {
      if (clearBtn) clearBtn.classList.remove('visible');
    }
    
    updateButtonAvailability();
  }

  function updateButtonAvailability() {
    // For each group, we want to see which values remain valid options
    // A value is valid if selecting it would result in at least one item being shown.
    // However, the standard behavior for multiple-select within a group (OR logic) 
    // vs between groups (AND logic) makes this tricky.
    
    // Simplified User Request: "if I clicked on Kitchen, only colours and styles on the image block with room Kitchen is clickable"
    // This implies we check valid options based on the currently filtered items.
    
    // Strategy:
    // 1. Determine the "current universe" of items that match active filters.
    //    BUT, if we are evaluating options for Group A, we shouldn't constrain by Group A's current selection 
    //    if we want to allow the user to expand the selection (e.g. Kitchen OR Living Room).
    //    Usually, in multi-select (OR), options are always visible, or they are filtered by *other* groups.
    
    // Let's implement: Options for Group X are available if there is at least one item that:
    // a) Has that option value for Group X.
    // b) Matches the active filters of ALL OTHER groups (Y, Z).
    
    ['room', 'colour', 'style'].forEach(targetGroup => {
      const buttons = document.querySelectorAll(`#filter-group-${targetGroup} .filter-btn`);
      
      buttons.forEach(btn => {
        const value = btn.dataset.value;
        // Test: if we select this specific value, does it behave with other groups?
        // We look for ONE item that has this value AND matches other active groups.
        
        const hasMatchingItem = items.some(item => {
          // 1. Does item have this specific value?
          const rawVals = item.getAttribute(`data-${targetGroup}`);
          const itemVals = rawVals ? rawVals.split(',').map(s => s.trim()) : [];
          if (!itemVals.includes(value)) return false;

          // 2. Does it match all OTHER active groups?
          for (const [otherGroup, selectedValues] of Object.entries(activeFilters)) {
            if (otherGroup === targetGroup) continue; // Skip the group we are evaluating
            
            if (selectedValues.length > 0) {
              const otherRawVals = item.getAttribute(`data-${otherGroup}`);
              const otherItemVals = otherRawVals ? otherRawVals.split(',').map(s => s.trim()) : [];
              // OR logic for the other group
              const matchesOther = selectedValues.some(v => otherItemVals.includes(v));
              if (!matchesOther) return false;
            }
          }
          
          return true;
        });

        if (hasMatchingItem) {
            btn.disabled = false;
            btn.style.opacity = '1';
            btn.style.pointerEvents = 'auto'; // Re-enable clicks
        } else {
           // We can hide it or disable it. User said "clickable", so disable is good.
            btn.disabled = true;
            btn.style.opacity = '0.3'; 
            btn.style.pointerEvents = 'none'; // Prevent clicks
        }
      });
    });
  }

  if (clearBtn) {
    clearBtn.addEventListener('click', () => {
      // Reset state
      for (const key in activeFilters) {
        activeFilters[key] = [];
      }
      // Remove active classes
      document.querySelectorAll('.filter-btn').forEach(btn => {
        btn.classList.remove('active');
        // Re-enable everything
        btn.disabled = false;
        btn.style.opacity = '1';
        btn.style.pointerEvents = 'auto';
      });
      applyFilters();
    });
  }
  
  // Lightbox Logic
  const lightbox = document.getElementById('masonry-lightbox');
  const lightboxContent = document.getElementById('masonry-lightbox-content');
  const closeBtn = document.querySelector('.masonry-lightbox-close');
  
  // Use delegation because items might be re-rendered or simpler to manage
  // Wait, items are static here but let's stick to direct binding as before, but correct the nesting.
  // The previous nesting was inside the clearBtn listener which was WRONG.
  
  document.querySelectorAll('.masonry-zoom-btn').forEach(btn => {
    btn.addEventListener('click', (e) => {
      e.stopPropagation(); // Prevents bubbling if needed
      const itemContent = btn.closest('.masonry-item-content');
      
      // Clone the content
      // We want the image, overlay, and hotspots. The button itself isn't needed in the lightbox.
      // But simply cloning masonry-item-content deeply is easiest.
      const clone = itemContent.cloneNode(true);
      
      // Remove the zoom button from the clone
      const zoomBtn = clone.querySelector('.masonry-zoom-btn');
      if (zoomBtn) zoomBtn.remove();
      
      // Clear previous content and append new
      lightboxContent.innerHTML = '';
      lightboxContent.appendChild(clone);
      
      // Display lightbox
      lightbox.classList.add('active');
      document.body.style.overflow = 'hidden'; // Prevent scrolling background
    });
  });
  
  function closeLightbox() {
    lightbox.classList.remove('active');
    document.body.style.overflow = '';
    lightboxContent.innerHTML = ''; // Cleanup
  }
  
  if(closeBtn) {
    closeBtn.addEventListener('click', closeLightbox);
  }
  
  // Close on outside click
  lightbox.addEventListener('click', (e) => {
    if (e.target === lightbox) {
      closeLightbox();
    }
  });
  
  // Close on Escape key
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && lightbox.classList.contains('active')) {
      closeLightbox();
    }
  });

  // Initialize
  ['room', 'colour', 'style'].forEach(group => {
    const values = getUniqueValues(group);
    createButtons(group, values);
  });
});

</script>